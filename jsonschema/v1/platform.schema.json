{
  "$defs": {
    "BrakeNormalization": {
      "description": "pedals トピックの brake=1.0 が何を意味するか。",
      "enum": [
        "stroke",
        "pressure",
        "switch"
      ],
      "title": "BrakeNormalization",
      "type": "string"
    },
    "CameraConfig": {
      "additionalProperties": false,
      "description": "カメラの構成情報 (modality=camera のチャネルのみ)。すべて公称値。",
      "properties": {
        "height_px": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "画像高さ [px]",
          "title": "Height Px"
        },
        "horizontal_fov_rad": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 6.283185307179586,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "水平画角 [rad] (公称値)",
          "title": "Horizontal Fov Rad"
        },
        "intrinsics_model": {
          "anyOf": [
            {
              "$ref": "#/$defs/CameraIntrinsicsModel"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "期待する内部パラメータモデル (実測係数は calibration 側)"
        },
        "width_px": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "画像幅 [px]",
          "title": "Width Px"
        }
      },
      "title": "CameraConfig",
      "type": "object"
    },
    "CameraIntrinsicsModel": {
      "description": "カメラ内部パラメータの型参照 (構成上の宣言)。\n\n実測係数は calibration.py (CameraIntrinsics) が持つ。ここでは\n「このカメラのキャリブがどのモデルで表現されるべきか」だけを宣言する。",
      "enum": [
        "pinhole_plumb_bob",
        "fisheye_equidistant"
      ],
      "title": "CameraIntrinsicsModel",
      "type": "string"
    },
    "ChannelSpec": {
      "additionalProperties": false,
      "description": "platform の sensor_rig を構成する 1 チャネルの定義。",
      "properties": {
        "camera": {
          "anyOf": [
            {
              "$ref": "#/$defs/CameraConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "カメラ構成情報。modality=camera のときのみ指定可"
        },
        "channel": {
          "description": "正規チャネル名 (CAM_FRONT 等)",
          "title": "Channel",
          "type": "string"
        },
        "modality": {
          "$ref": "#/$defs/Modality"
        },
        "nominal_mount": {
          "anyOf": [
            {
              "$ref": "#/$defs/Pose"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "base_link 基準の設計搭載位置 (公称値)。カメラは光学フレーム。実測搭載位置は calibration 側"
        }
      },
      "required": [
        "channel",
        "modality"
      ],
      "title": "ChannelSpec",
      "type": "object"
    },
    "Modality": {
      "enum": [
        "camera",
        "lidar",
        "radar",
        "gnss",
        "imu",
        "vehicle"
      ],
      "title": "Modality",
      "type": "string"
    },
    "Pose": {
      "additionalProperties": false,
      "description": "位置と姿勢の組。frame は文脈 (スキーマ側) が規定する。",
      "properties": {
        "rotation": {
          "$ref": "#/$defs/QuaternionXYZW"
        },
        "translation": {
          "$ref": "#/$defs/Vector3"
        }
      },
      "required": [
        "translation",
        "rotation"
      ],
      "title": "Pose",
      "type": "object"
    },
    "QuaternionXYZW": {
      "additionalProperties": false,
      "description": "単位クォータニオン。ROS 順 (x, y, z, w) で格納する。\n\n許容誤差 1e-3 以内で正規化されていることを検証する。\nnuScenes の (w, x, y, z) への並び替えはエクスポータの責務。",
      "properties": {
        "w": {
          "title": "W",
          "type": "number"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "z": {
          "title": "Z",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z",
        "w"
      ],
      "title": "QuaternionXYZW",
      "type": "object"
    },
    "SpeedSignRule": {
      "description": "ソース (CAN / CARLA) の速度値の符号規則。\n\nshasou の契約は「m/s・後退で負」(constants.py)。ソースがこの契約と\n異なる場合にアダプタがどう変換すべきかを宣言する。",
      "enum": [
        "signed",
        "abs_with_reverse_flag"
      ],
      "title": "SpeedSignRule",
      "type": "string"
    },
    "Vector3": {
      "additionalProperties": false,
      "properties": {
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "z": {
          "title": "Z",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "title": "Vector3",
      "type": "object"
    },
    "VehicleParams": {
      "additionalProperties": false,
      "description": "車両固有パラメータ。CARLA ブリッジ / CAN デコーダのアダプタが変換に使う。\n\nPlatform にネストされる区画であり、単独で配布されることはない。車種の\n識別は Platform.vehicle_type が唯一の正 (ここには持たない)。\n\nplatform 定義は手書きされうるため、すべて optional。値が無いパラメータを\n必要とするアダプタは、その時点でエラーにする。",
      "properties": {
        "base_link_offset": {
          "anyOf": [
            {
              "$ref": "#/$defs/Vector3"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "車両モデル原点→後軸中心のオフセット [m]。右手系"
        },
        "brake_normalization": {
          "anyOf": [
            {
              "$ref": "#/$defs/BrakeNormalization"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "pedals トピックの brake=1.0 の定義"
        },
        "max_steer_angle_rad": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 3.141592653589793,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "最大前輪実舵角 [rad]。CARLA 正規化 steer [-1,1] → rad 変換用",
          "title": "Max Steer Angle Rad"
        },
        "speed_sign_rule": {
          "anyOf": [
            {
              "$ref": "#/$defs/SpeedSignRule"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ソース速度の符号規則。契約 (m/s・後退負) への変換方法"
        },
        "steering_gear_ratio": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ハンドル角→前輪実舵角の変換比 (実舵角 = ハンドル角 / ratio)。角度は rad・左転舵正",
          "title": "Steering Gear Ratio"
        }
      },
      "title": "VehicleParams",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "platform 定義。sensor_rig (チャネル集合) + vehicle_type。",
  "properties": {
    "platform_id": {
      "description": "platform ID (フォルダ名と一致)",
      "title": "Platform Id",
      "type": "string"
    },
    "sensor_rig": {
      "description": "この platform のセンサ構成。実チャネル集合の正",
      "items": {
        "$ref": "#/$defs/ChannelSpec"
      },
      "title": "Sensor Rig",
      "type": "array"
    },
    "vehicle_params": {
      "anyOf": [
        {
          "$ref": "#/$defs/VehicleParams"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "車両固有パラメータ。アダプタが変換に使う"
    },
    "vehicle_type": {
      "title": "Vehicle Type",
      "type": "string"
    }
  },
  "required": [
    "platform_id",
    "vehicle_type",
    "sensor_rig"
  ],
  "title": "Platform",
  "type": "object"
}
